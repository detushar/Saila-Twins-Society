d\\\x22kpi-sub\\\x22 style\x3d\\\x22margin-top:5px; padding-top:5px; border-top:1px solid #f0e8cc;\\\x22\x3e\\n        \x3cspan style\x3d\\\x22font-size:9px;color:var(--mute);text-transform:uppercase;letter-spacing:0.4px;\\\x22\x3eExp This Month\x3c\\\/span\x3e\x3cbr\x3e\\n        \x3cspan id\x3d\\\x22k-cur-exp\\\x22 style\x3d\\\x22font-size:12px;font-weight:700;color:var(--red);\\\x22\x3e\\u2014\x3c\\\/span\x3e\\n      \x3c\\\/div\x3e\\n    \x3c\\\/div\x3e\\n  \x3c\\\/div\x3e\\n\\n  \\n  \x3cdiv class\x3d\\\x22section-title\\\x22\x3ePending Maintenance \\u2014 This Month\x3c\\\/div\x3e\\n  \x3cdiv class\x3d\\\x22unpaid-card\\\x22 id\x3d\\\x22unpaid-card\\\x22\x3e\\n    \x3cdiv id\x3d\\\x22unpaid-body\\\x22\x3e\x3cdiv class\x3d\\\x22all-paid\\\x22\x3eLoading\\u2026\x3c\\\/div\x3e\x3c\\\/div\x3e\\n  \x3c\\\/div\x3e\\n\\n  \\n  \x3cdiv class\x3d\\\x22section-title\\\x22\x3eLast 3 Month Expense Details\x3c\\\/div\x3e\\n  \x3cdiv class\x3d\\\x22card\\\x22 style\x3d\\\x22padding:14px 10px;\\\x22\x3e\\n    \x3cdiv id\x3d\\\x22last3-wrap\\\x22 style\x3d\\\x22overflow-x:auto\\\x22\x3e\\n      \x3ctable class\x3d\\\x22exp-table\\\x22 id\x3d\\\x22last3-table\\\x22\x3e\\n        \x3cthead\x3e\x3ctr id\x3d\\\x22last3-head\\\x22\x3e\x3c\\\/tr\x3e\x3c\\\/thead\x3e\\n        \x3ctbody id\x3d\\\x22last3-body\\\x22\x3e\x3c\\\/tbody\x3e\\n      \x3c\\\/table\x3e\\n    \x3c\\\/div\x3e\\n  \x3c\\\/div\x3e\\n\\n  \\n  \x3cdiv class\x3d\\\x22section-title\\\x22\x3eExpense by Category (YTD)\x3c\\\/div\x3e\\n  \x3cdiv class\x3d\\\x22card\\\x22\x3e\\n    \x3ccanvas id\x3d\\\x22chart-cat\\\x22 height\x3d\\\x22240\\\x22\x3e\x3c\\\/canvas\x3e\\n  \x3c\\\/div\x3e\\n\\n  \\n  \x3cdiv class\x3d\\\x22section-title\\\x22\x3eCollection vs Expense \\u2014 12 Months\x3c\\\/div\x3e\\n  \x3cdiv class\x3d\\\x22card\\\x22\x3e\\n    \x3ccanvas id\x3d\\\x22chart-combined\\\x22\x3e\x3c\\\/canvas\x3e\\n  \x3c\\\/div\x3e\\n\\n  \\n  \x3cdiv class\x3d\\\x22section-title\\\x22\x3eTop Expenses\x3c\\\/div\x3e\\n  \x3cdiv class\x3d\\\x22top-exp-card\\\x22\x3e\\n    \x3ch2\x3e⭐ Highest Expenses \\u2014 All Time\x3c\\\/h2\x3e\\n    \x3cdiv id\x3d\\\x22top-expenses\\\x22\x3e\x3c\\\/div\x3e\\n  \x3c\\\/div\x3e\\n\\n\x3c\\\/div\x3e\\n\\n\x3cdiv id\x3d\\\x22loading\\\x22 class\x3d\\\x22loading\\\x22\x3eLoading dashboard\\u2026\x3c\\\/div\x3e\\n\\n\x3cbutton class\x3d\\\x22refresh\\\x22 id\x3d\\\x22refreshBtn\\\x22 onclick\x3d\\\x22load()\\\x22 title\x3d\\\x22Refresh\\\x22\x3e↻\x3c\\\/button\x3e\\n\\n\x3cscript\x3e\\n  const fmtINR \x3d n \x3d\x3e \x27\\u20b9\x27 + Math.round(Number(n) || 0).toLocaleString(\x27en-IN\x27);\\n  const compact \x3d n \x3d\x3e \x7b\\n    const v \x3d Number(n) || 0;\\n    if (Math.abs(v) \x3e\x3d 100000) return \x27\\u20b9\x27 + (v\/100000).toFixed(1) + \x27L\x27;\\n    if (Math.abs(v) \x3e\x3d 1000)   return \x27\\u20b9\x27 + (v\/1000).toFixed(1) + \x27k\x27;\\n    return \x27\\u20b9\x27 + v;\\n  \x7d;\\n\\n  let catChart, cmbChart;\\n\\n  function load() \x7b\\n    document.getElementById(\x27refreshBtn\x27).classList.add(\x27spin\x27);\\n    document.getElementById(\x27content\x27).style.display \x3d \x27none\x27;\\n    document.getElementById(\x27loading\x27).style.display  \x3d \x27block\x27;\\n    document.getElementById(\x27loading\x27).className      \x3d \x27loading\x27;\\n    document.getElementById(\x27loading\x27).textContent    \x3d \x27Loading dashboard\\u2026\x27;\\n    google.script.run\\n      .withSuccessHandler(d \x3d\x3e \x7b\\n        render(d);\\n        document.getElementById(\x27refreshBtn\x27).classList.remove(\x27spin\x27);\\n      \x7d)\\n      .withFailureHandler(err \x3d\x3e \x7b\\n        document.getElementById(\x27loading\x27).className  \x3d \x27error\x27;\\n        document.getElementById(\x27loading\x27).textContent \x3d \x27Error: \x27 + (err \x26\x26 err.message ? err.message : err);\\n        document.getElementById(\x27refreshBtn\x27).classList.remove(\x27spin\x27);\\n      \x7d)\\n      .getDashboardData();\\n  \x7d\\n\\n  function esc(s) \x7b\\n    return String(s || \x27\x27).replace(\/\x5b\x26\x3c\x3e\\\x22\x27\x5d\/g,\\n      c \x3d\x3e (\x7b\x27\x26\x27:\x27\x26amp;\x27,\x27\x3c\x27:\x27\x26lt;\x27,\x27\x3e\x27:\x27\x26gt;\x27,\x27\\\x22\x27:\x27\x26quot;\x27,\\\x22\x27\\\x22:\x27\x26#39;\x27\x7d\x5bc\x5d));\\n  \x7d\\n\\n  function render(d) \x7b\\n    document.getElementById(\x27loading\x27).style.display \x3d \x27none\x27;\\n    document.getElementById(\x27content\x27).style.display \x3d \x27block\x27;\\n    document.getElementById(\x27stamp\x27).textContent     \x3d \x27Updated \x27 + d.generatedAt;\\n\\n    \\n    document.getElementById(\x27k-soc\x27).textContent   \x3d compact(d.societyBalance);\\n    document.getElementById(\x27k-wtp\x27).textContent   \x3d compact(d.wtpBalance);\\n    document.getElementById(\x27k-total\x27).textContent \x3d compact(d.latestBank);\\n\\n    \\n    const target \x3d d.maintTarget || 1;\\n    const pct    \x3d Math.min(100, Math.round((d.currentMonthCollection \/ target) * 100));\\n    document.getElementById(\x27k-maint-frac\x27).textContent \x3d compact(d.currentMonthCollection) + \x27 \/ \x27 + compact(d.maintTarget);\\n    document.getElementById(\x27maint-fill\x27).style.width   \x3d pct + \x27%\x27;\\n    document.getElementById(\x27maint-pct\x27).textContent    \x3d pct + \x27% collected\x27;\\n    document.getElementById(\x27k-cih-card\x27).textContent   \x3d compact(d.cashInHand);\\n    document.getElementById(\x27k-ctk\x27).textContent        \x3d compact(d.caretakerLastPayment);\\n    document.getElementById(\x27k-ctk-date\x27).textContent   \x3d d.caretakerLastDate ? d.caretakerLastDate : \x27\x27;\\n    document.getElementById(\x27k-cur-exp\x27).textContent    \x3d compact(d.currentMonthExpense);\\n\\n    \\n    const unpaidDiv \x3d document.getElementById(\x27unpaid-body\x27);\\n    if (!d.unpaidFlats || d.unpaidFlats.length \x3d\x3d\x3d 0) \x7b\\n      unpaidDiv.innerHTML \x3d \x27\x3cdiv class\x3d\\\x22all-paid\\\x22\x3e✅ All flats have paid for this month\x3c\\\/div\x3e\x27;\\n    \x7d else \x7b\\n      \\n      const byBld \x3d \x7b\x7d;\\n      d.unpaidFlats.forEach(f \x3d\x3e \x7b\\n        if (!byBld\x5bf.building\x5d) byBld\x5bf.building\x5d \x3d \x5b\x5d;\\n        byBld\x5bf.building\x5d.push(f.flat);\\n      \x7d);\\n      const total \x3d d.unpaidFlats.length;\\n      unpaidDiv.innerHTML \x3d\\n        `\x3cdiv class\x3d\\\x22up-head\\\x22\x3e⚠ $\x7btotal\x7d flat$\x7btotal \x3e 1 ? \x27s\x27 : \x27\x27\x7d yet to pay\x3c\\\/div\x3e` +\\n        Object.entries(byBld).map((\x5bbld, flats\x5d) \x3d\x3e\\n          `\x3cdiv class\x3d\\\x22unpaid-bld\\\x22\x3e$\x7besc(bld)\x7d\x3c\\\/div\x3e\\n           \x3cdiv class\x3d\\\x22flat-chips\\\x22\x3e$\x7bflats.map(f \x3d\x3e `\x3cspan class\x3d\\\x22flat-chip\\\x22\x3e$\x7besc(f)\x7d\x3c\\\/span\x3e`).join(\x27\x27)\x7d\x3c\\\/div\x3e`\\n        ).join(\x27\x27);\\n    \x7d\\n\\n    \\n    const thead \x3d document.getElementById(\x27last3-head\x27);\\n    const tbody \x3d document.getElementById(\x27last3-body\x27);\\n    thead.innerHTML \x3d \x27\x3cth\x3eCategory\x3c\\\/th\x3e\x27 +\\n      (d.last3Labels || \x5b\x5d).map(l \x3d\x3e `\x3cth\x3e$\x7besc(l)\x7d\x3c\\\/th\x3e`).join(\x27\x27) +\\n      \x27\x3cth\x3eTotal\x3c\\\/th\x3e\x27;\\n\\n    if (d.last3Table \x26\x26 d.last3Table.length) \x7b\\n      tbody.innerHTML \x3d d.last3Table.map(row \x3d\x3e\\n        `\x3ctr\x3e\\n          \x3ctd\x3e$\x7besc(row.category)\x7d\x3c\\\/td\x3e\\n          $\x7b(row.months || \x5b\x5d).map(v \x3d\x3e `\x3ctd class\x3d\\\x22$\x7bv ? \x27\x27 : \x27zero\x27\x7d\\\x22\x3e$\x7bv ? compact(v) : \x27\\u2013\x27\x7d\x3c\\\/td\x3e`).join(\x27\x27)\x7d\\n          \x3ctd\x3e$\x7bcompact(row.total)\x7d\x3c\\\/td\x3e\\n        \x3c\\\/tr\x3e`\\n      ).join(\x27\x27) +\\n      `\x3ctr\x3e\\n        \x3ctd\x3eTotal\x3c\\\/td\x3e\\n        $\x7b(d.last3Totals || \x5b\x5d).map(v \x3d\x3e `\x3ctd\x3e$\x7bcompact(v)\x7d\x3c\\\/td\x3e`).join(\x27\x27)\x7d\\n        \x3ctd\x3e$\x7bcompact((d.last3Totals || \x5b\x5d).reduce((a,b) \x3d\x3e a+b, 0))\x7d\x3c\\\/td\x3e\\n      \x3c\\\/tr\x3e`;\\n    \x7d else \x7b\\n      tbody.innerHTML \x3d \x27\x3ctr\x3e\x3ctd colspan\x3d\\\x225\\\x22 class\x3d\\\x22empty\\\x22 style\x3d\\\x22text-align:center\\\x22\x3eNo data yet\x3c\\\/td\x3e\x3c\\\/tr\x3e\x27;\\n    \x7d\\n\\n    \/\/ ── Expense by category \\u2014 doughnut ────────────────────────────────────────\\n    const catColors \x3d \x5b\x27#4472C4\x27,\x27#C62828\x27,\x27#2E7D32\x27,\x27#BF8F00\x27,\x27#7B1FA2\x27,\\n                       \x27#0097A7\x27,\x27#EF6C00\x27,\x27#455A64\x27,\x27#00838F\x27,\x27#9E9E9E\x27\x5d;\\n    if (catChart) catChart.destroy();\\n    catChart \x3d new Chart(document.getElementById(\x27chart-cat\x27), \x7b\\n      type: \x27doughnut\x27,\\n      data: \x7b\\n        labels  : d.categories.map(c \x3d\x3e c.category),\\n        datasets: \x5b\x7b data: d.categories.map(c \x3d\x3e c.amount), backgroundColor: catColors, borderWidth: 0 \x7d\x5d\\n      \x7d,\\n      options: \x7b\\n        cutout : \x2756%\x27,\\n        plugins: \x7b\\n          legend : \x7b position: \x27bottom\x27, labels: \x7b font: \x7b size: 10 \x7d, boxWidth: 10, padding: 7 \x7d \x7d,\\n          tooltip: \x7b callbacks: \x7b label: ctx \x3d\x3e ctx.label + \x27: \x27 + fmtINR(ctx.raw) \x7d \x7d\\n        \x7d\\n      \x7d\\n    \x7d);\\n\\n    \/\/ ── Collection vs Expense \\u2014 horizontal bar ────────────────────────────────\\n    const barH \x3d Math.max(200, d.combined.length * 28);\\n    document.getElementById(\x27chart-combined\x27).height \x3d barH;\\n\\n    if (cmbChart) cmbChart.destroy();\\n    cmbChart \x3d new Chart(document.getElementById(\x27chart-combined\x27), \x7b\\n      type: \x27bar\x27,\\n      data: \x7b\\n        labels  : d.combined.map(m \x3d\x3e m.label),\\n        datasets: \x5b\\n          \x7b label: \x27Collection\x27, data: d.combined.map(m \x3d\x3e m.collection), backgroundColor: \x27#2E7D32\x27, borderRadius: 3 \x7d,\\n          \x7b label: \x27Expense\x27,    data: d.combined.map(m \x3d\x3e m.expense),    backgroundColor: \x27#C62828\x27, borderRadius: 3 \x7d\\n        \x5d\\n      \x7d,\\n      options: \x7b\\n        indexAxis: \x27y\x27,\\n        plugins: \x7b\\n          legend : \x7b position: \x27bottom\x27, labels: \x7b font: \x7b size: 10 \x7d, boxWidth: 12 \x7d \x7d,\\n          tooltip: \x7b callbacks: \x7b label: ctx \x3d\x3e ctx.dataset.label + \x27: \x27 + fmtINR(ctx.raw) \x7d \x7d\\n        \x7d,\\n        scales: \x7b\\n          x: \x7b ticks: \x7b callback: v \x3d\x3e compact(v), font: \x7b size: 9 \x7d \x7d, grid: \x7b color: \x27#eef0f4\x27 \x7d \x7d,\\n          y: \x7b ticks: \x7b font: \x7b size: 10 \x7d \x7d, grid: \x7b display: false \x7d \x7d\\n        \x7d\\n      \x7d\\n    \x7d);\\n\\n    \/\/ ── Top expenses ──────────────────────────────────────────────────────────\\n    const topDiv \x3d document.getElementById(\x27top-expenses\x27);\\n    topDiv.innerHTML \x3d (d.topExpenses \x26\x26 d.topExpenses.length)\\n      ? d.topExpenses.map((e, i) \x3d\x3e\\n          `\x3cdiv class\x3d\\\x22tx\\\x22\x3e\\n            \x3cdiv class\x3d\\\x22tx-inner\\\x22\x3e\\n              \x3cdiv class\x3d\\\x22rank-badge\\\x22\x3e$\x7bi+1\x7d\x3c\\\/div\x3e\\n              \x3cdiv class\x3d\\\x22left\\\x22\x3e\\n                \x3cdiv class\x3d\\\x22item\\\x22\x3e$\x7besc(e.item || e.category)\x7d\x3c\\\/div\x3e\\n                \x3cdiv class\x3d\\\x22meta\\\x22\x3e\x3cspan class\x3d\\\x22cat\\\x22\x3e$\x7besc(e.category)\x7d\x3c\\\/span\x3e · $\x7besc(e.date)\x7d\x3c\\\/div\x3e\\n              \x3c\\\/div\x3e\\n            \x3c\\\/div\x3e\\n            \x3cdiv class\x3d\\\x22amt\\\x22\x3e$\x7bfmtINR(e.amount)\x7d\x3c\\\/div\x3e\\n          \x3c\\\/div\x3e`).join(\x27\x27)\\n      : \x27\x3cdiv class\x3d\\\x22empty\\\x22\x3eNo expenses logged yet.\x3c\\\/div\x3e\x27;\\n  \x7d\\n\\n  load();\\n\x3c\\\/script\x3e\\n\x3c\\\/body\x3e\\n\x3c\\\/html\x3e\\n\x22,\x22ncc\x22:\x22\x7b\\\x22awhs\\\x22:true\x7d\x22\x7d", "", undefined, true , false  , "false", "https:\/\/n-ubne4xt73pmu7xoxdt6bwt7sme7sq3hwddvl7yi-0lu-script.googleusercontent.com", "https:\/\/drive.google.com\/abuse?id\x3dAKkXjoyMerea32g9o9ZR3c2S1w6NLN_qbeqkEftCD5-PuR-GEuAVXj4D5N8ktd6pHbtSOY3uNAacGwBcKEiY065GkQW2EjyPWvGCgBbj%3A0\x26docurl\x3dhttps%3A%2F%2Fscript.google.com%2Fmacros%2Fs%2FAKfycbz23uiQuQGOapghi_ky6oQ3_xRFPxS-ogoj1cN4V5WiKaFGI4he4V90YM6P3T3tQcYV%2Fexec%3Faction%3Ddata");}
el.src = 'https:\/\/n-ubne4xt73pmu7xoxdt6bwt7sme7sq3hwddvl7yi-0lu-script.googleusercontent.com\/userCodeAppPanel';
}());
